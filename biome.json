{
  "$schema": "https://biomejs.dev/schemas/1.9.4/schema.json",
  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "indentWidth": 2
  },
  "linter": {
    "enabled": true,
    "rules": {
      "recommended": true
    }
  },
  "files": {
    "ignore": [
      ".omx",
      ".next",
      "node_modules",
      "contracts/out",
      "contracts/cache",
      "contracts/broadcast",
      ".tmp",
      "data/store.json",
      ".env.local"
    ]
  }
}
